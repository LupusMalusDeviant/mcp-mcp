<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Zentrale Paketverwaltung (NU1507) verlangt eindeutige Quellen: Maschinen-Quellen
       (z. B. corecms) werden hier bewusst ausgeblendet — dieses Repo nutzt nur nuget.org. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>

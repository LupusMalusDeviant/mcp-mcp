@page "/logs"
@attribute [Authorize(Policy = UiPolicies.Authenticated)]
@inject IAuditQuery AuditQuery
@inject IJSRuntime JS

<h1>Audit-Log</h1>
<p class="muted">Wer hat wann was aufgerufen — inkl. verweigerter Calls (FR-21/23).</p>

<div class="card">
    <div class="row">
        <div><label>Tool enthält</label><input @bind="_tool" placeholder="z.B. github__" /></div>
        <div>
            <label>Status</label>
            <select @bind="_status">
                <option value="">(alle)</option>
                @foreach (var s in Enum.GetValues<InvocationStatus>())
                {
                    <option value="@s">@s</option>
                }
            </select>
        </div>
        <div>
            <label>Herkunft</label>
            <select @bind="_origin">
                <option value="">(alle)</option>
                @foreach (var o in Enum.GetValues<CallOrigin>())
                {
                    <option value="@o">@o</option>
                }
            </select>
        </div>
        <div><label>Seit (Stunden)</label><input type="number" @bind="_hours" min="1" /></div>
    </div>
    <div class="toolbar" style="margin-top:1rem">
        <button @onclick="() => Search(1)">Suchen</button>
        <button class="btn-ghost" @onclick="ExportJson">Export JSON</button>
        <button class="btn-ghost" @onclick="ExportCsv">Export CSV</button>
        <span class="muted">@_result.TotalCount Treffer</span>
    </div>
</div>

<div class="card">
    <div class="table-wrap">
        <table>
            <thead><tr><th>Zeit (UTC)</th><th>Herkunft</th><th>Aufrufer</th><th>Tool</th><th>Status</th><th>Dauer</th></tr></thead>
            <tbody>
                @foreach (var e in _result.Items)
                {
                    <tr>
                        <td class="mono">@e.Timestamp.UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture)</td>
                        <td>@e.Origin</td>
                        <td class="mono muted">@(e.Caller?.ToString() ?? "—")</td>
                        <td class="mono">@(e.Tool ?? "—")</td>
                        <td>@StatusBadge(e.Status)</td>
                        <td class="muted">@(e.Duration is { } d ? $"{d.TotalMilliseconds:0} ms" : "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (_result.TotalCount > _result.PageSize)
    {
        <div class="toolbar" style="margin-top:1rem">
            <button class="btn-sm btn-ghost" disabled="@(_page <= 1)" @onclick="() => Search(_page - 1)">‹ Zurück</button>
            <span class="muted">Seite @_page / @TotalPages</span>
            <button class="btn-sm btn-ghost" disabled="@(_page >= TotalPages)" @onclick="() => Search(_page + 1)">Weiter ›</button>
        </div>
    }
</div>

@code {
    private string _tool = "", _status = "", _origin = "";
    private int _hours = 24, _page = 1;
    private PagedResult<AuditEvent> _result = new([], 0, 1, 50);

    private int TotalPages => (int)Math.Ceiling(_result.TotalCount / (double)_result.PageSize);

    protected override Task OnInitializedAsync() => Search(1);

    private async Task Search(int page)
    {
        _page = Math.Max(1, page);
        _result = await AuditQuery.QueryAsync(BuildFilter(_page, 50), CancellationToken.None);
    }

    private AuditFilter BuildFilter(int page, int pageSize) => new(
        From: DateTimeOffset.UtcNow.AddHours(-Math.Max(1, _hours)),
        Tool: string.IsNullOrWhiteSpace(_tool) ? null : _tool.Trim(),
        Status: Enum.TryParse<InvocationStatus>(_status, out var s) ? s : null,
        Page: page,
        PageSize: pageSize);

    private static RenderFragment StatusBadge(InvocationStatus? status) => builder =>
    {
        if (status is null) { builder.AddContent(0, "—"); return; }
        var css = status == InvocationStatus.Success ? "badge-ok"
            : status == InvocationStatus.Denied ? "badge-warn" : "badge-err";
        builder.OpenElement(1, "span");
        builder.AddAttribute(2, "class", $"badge {css}");
        builder.AddContent(3, status.ToString());
        builder.CloseElement();
    };

    private async Task ExportJson()
    {
        var all = await AuditQuery.QueryAsync(BuildFilter(1, 5000), CancellationToken.None);
        var json = System.Text.Json.JsonSerializer.Serialize(all.Items, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        await Download($"audit-{DateTime.UtcNow:yyyyMMdd-HHmmss}.json", "application/json", json);
    }

    private async Task ExportCsv()
    {
        var all = await AuditQuery.QueryAsync(BuildFilter(1, 5000), CancellationToken.None);
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("timestamp,origin,caller,tool,status,durationMs");
        foreach (var e in all.Items)
        {
            sb.Append(e.Timestamp.UtcDateTime.ToString("O", CultureInfo.InvariantCulture)).Append(',')
              .Append(e.Origin).Append(',')
              .Append(e.Caller?.ToString() ?? "").Append(',')
              .Append(Csv(e.Tool)).Append(',')
              .Append(e.Status?.ToString() ?? "").Append(',')
              .Append((e.Duration?.TotalMilliseconds ?? 0).ToString("0", CultureInfo.InvariantCulture))
              .AppendLine();
        }
        await Download($"audit-{DateTime.UtcNow:yyyyMMdd-HHmmss}.csv", "text/csv", sb.ToString());
    }

    private static string Csv(string? value)
        => value is null ? "" : value.Contains(',') ? $"\"{value.Replace("\"", "\"\"")}\"" : value;

    private async Task Download(string filename, string mime, string content)
    {
        var bytes = System.Text.Encoding.UTF8.GetBytes(content);
        await JS.InvokeVoidAsync("mcpmcpDownload", filename, mime, Convert.ToBase64String(bytes));
    }
}

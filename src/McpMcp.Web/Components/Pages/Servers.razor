@page "/servers"
@attribute [Authorize(Policy = UiPolicies.Operator)]
@inject IUpstreamSupervisor Supervisor
@inject IUpstreamConnectionTester Tester
@inject IAuditSink Audit
@inject TimeProvider Time
@inject AuthenticationStateProvider AuthState

<h1>Server-Verwaltung</h1>
<p class="muted">Upstream-MCP-Server und OpenAPI-Quellen zur Laufzeit hinzufügen, ohne Neustart (FR-06/34).</p>

<div class="card">
    <h3 style="margin-top:0">Angeschlossene Server</h3>
    @if (_statuses.Count == 0)
    {
        <p class="muted">Noch nichts angeschlossen.</p>
    }
    else
    {
        <div class="table-wrap">
            <table>
                <thead><tr><th>Slug</th><th>Status</th><th>Tools</th><th>Letzter Fehler</th><th></th></tr></thead>
                <tbody>
                    @foreach (var s in _statuses)
                    {
                        <tr>
                            <td class="mono">@s.Slug</td>
                            <td><StateBadge State="s.State" /></td>
                            <td>@s.ToolCount</td>
                            <td class="muted" style="max-width:260px">@(s.LastError ?? "—")</td>
                            <td style="white-space:nowrap">
                                @if (s.State == UpstreamState.Stopped)
                                {
                                    <button class="btn-sm btn-ghost" @onclick="() => SetEnabled(s.Id, true)">Aktivieren</button>
                                }
                                else
                                {
                                    <button class="btn-sm btn-ghost" @onclick="() => SetEnabled(s.Id, false)">Deaktivieren</button>
                                }
                                <button class="btn-sm btn-danger" @onclick="() => Remove(s.Id, s.Slug)">Entfernen</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="card">
    <h3 style="margin-top:0">Neuen Server anschließen</h3>
    <div class="row">
        <div>
            <label>Transport</label>
            <select @bind="_kind">
                <option value="@UpstreamTransportKind.Stdio">stdio (lokaler Prozess)</option>
                <option value="@UpstreamTransportKind.StreamableHttp">Streamable HTTP</option>
                <option value="@UpstreamTransportKind.OpenApi">OpenAPI-Import</option>
            </select>
        </div>
        <div>
            <label>Slug (Namespace)</label>
            <input @bind="_slug" placeholder="z.B. github" />
        </div>
        <div>
            <label>Anzeigename</label>
            <input @bind="_displayName" placeholder="GitHub" />
        </div>
    </div>

    @if (_kind == UpstreamTransportKind.Stdio)
    {
        <div class="row">
            <div style="flex:2"><label>Kommando</label><input @bind="_command" placeholder="npx" /></div>
            <div style="flex:3"><label>Argumente (durch Leerzeichen)</label><input @bind="_args" placeholder="-y @@modelcontextprotocol/server-github" /></div>
        </div>
        <label>Environment (KEY=VALUE pro Zeile)</label>
        <textarea class="mono" rows="3" @bind="_env" placeholder="GITHUB_TOKEN=ghp_..."></textarea>
    }
    else if (_kind == UpstreamTransportKind.StreamableHttp)
    {
        <label>Endpoint-URL</label>
        <input @bind="_httpUrl" placeholder="https://host/mcp" />
        <label>Header (KEY=VALUE pro Zeile)</label>
        <textarea class="mono" rows="2" @bind="_headers" placeholder="Authorization=Bearer ..."></textarea>
    }
    else
    {
        <div class="row">
            <div style="flex:2"><label>Spec-URL oder file://-Pfad</label><input @bind="_specUrl" placeholder="https://api.example.com/openapi.json" /></div>
            <div><label>Base-URL (optional)</label><input @bind="_baseUrl" placeholder="https://api.example.com" /></div>
        </div>
        <div class="row">
            <div>
                <label>Auth</label>
                <select @bind="_openApiAuth">
                    <option value="@OpenApiAuthKind.None">Keine</option>
                    <option value="@OpenApiAuthKind.Bearer">Bearer</option>
                    <option value="@OpenApiAuthKind.Basic">Basic (user:pass)</option>
                    <option value="@OpenApiAuthKind.ApiKeyHeader">API-Key-Header</option>
                </select>
            </div>
            <div><label>Credential</label><input @bind="_credential" type="password" /></div>
            @if (_openApiAuth == OpenApiAuthKind.ApiKeyHeader)
            {
                <div><label>Header-Name</label><input @bind="_apiKeyHeader" placeholder="X-Api-Key" /></div>
            }
        </div>
    }

    <div class="toolbar" style="margin-top:1rem">
        <button class="btn-ghost" @onclick="Test" disabled="@_busy">Verbindung testen</button>
        <button @onclick="Add" disabled="@_busy">Anschließen</button>
        @if (_message is not null)
        {
            <span class="@(_ok ? "msg-ok" : "msg-err")">@_message</span>
        }
    </div>
</div>

@code {
    private IReadOnlyList<UpstreamStatus> _statuses = [];
    private UpstreamTransportKind _kind = UpstreamTransportKind.Stdio;
    private string _slug = "", _displayName = "", _command = "", _args = "", _env = "";
    private string _httpUrl = "", _headers = "";
    private string _specUrl = "", _baseUrl = "", _credential = "", _apiKeyHeader = "X-Api-Key";
    private OpenApiAuthKind _openApiAuth = OpenApiAuthKind.None;
    private bool _busy, _ok;
    private string? _message;

    protected override void OnInitialized() => Reload();

    private void Reload() => _statuses = Supervisor.Statuses.OrderBy(s => s.Slug).ToList();

    private async Task<string> UserAsync()
        => (await AuthState.GetAuthenticationStateAsync()).User.Identity?.Name ?? "?";

    private UpstreamServerConfig? BuildConfig(out string? error)
    {
        error = null;
        try
        {
            return _kind switch
            {
                UpstreamTransportKind.Stdio => new UpstreamServerConfig(
                    _slug.Trim(), Display(), _kind, true,
                    Stdio: new StdioTransportOptions(
                        _command.Trim(),
                        _args.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries),
                        ParseKeyValues(_env))),
                UpstreamTransportKind.StreamableHttp => new UpstreamServerConfig(
                    _slug.Trim(), Display(), _kind, true,
                    Http: new HttpTransportOptions(new Uri(_httpUrl.Trim()), ParseKeyValues(_headers))),
                _ => new UpstreamServerConfig(
                    _slug.Trim(), Display(), _kind, true,
                    OpenApi: new OpenApiTransportOptions(
                        new Uri(_specUrl.Trim()),
                        string.IsNullOrWhiteSpace(_baseUrl) ? null : new Uri(_baseUrl.Trim()),
                        _openApiAuth,
                        string.IsNullOrWhiteSpace(_credential) ? null : _credential,
                        _openApiAuth == OpenApiAuthKind.ApiKeyHeader ? _apiKeyHeader.Trim() : null)),
            };
        }
        catch (Exception ex)
        {
            error = $"Konfiguration ungültig: {ex.Message}";
            return null;
        }
    }

    private string Display() => string.IsNullOrWhiteSpace(_displayName) ? _slug.Trim() : _displayName.Trim();

    private static IReadOnlyDictionary<string, string>? ParseKeyValues(string text)
    {
        var dict = new Dictionary<string, string>();
        foreach (var line in text.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            var idx = line.IndexOf('=');
            if (idx > 0)
            {
                dict[line[..idx].Trim()] = line[(idx + 1)..].Trim();
            }
        }
        return dict.Count > 0 ? dict : null;
    }

    private async Task Test()
    {
        _busy = true; _message = null;
        var config = BuildConfig(out var err);
        if (config is null) { _ok = false; _message = err; _busy = false; return; }

        var result = await Tester.TestAsync(config, CancellationToken.None);
        _ok = result.Success;
        _message = result.Success
            ? $"Verbindung ok — {result.ToolCount} Tool(s) entdeckt."
            : $"Fehlgeschlagen: {result.Error}";
        _busy = false;
    }

    private async Task Add()
    {
        _busy = true; _message = null;
        var config = BuildConfig(out var err);
        if (config is null) { _ok = false; _message = err; _busy = false; return; }

        try
        {
            var id = await Supervisor.AddAsync(config, CancellationToken.None);
            UiAudit.Record(Audit, Time, await UserAsync(), AuditEventKind.ConfigChanged, $"server-added:{config.Slug}", id);
            _ok = true; _message = $"'{config.Slug}' angeschlossen.";
            _slug = _displayName = _command = _args = _env = _httpUrl = _headers = _specUrl = _baseUrl = _credential = "";
            Reload();
        }
        catch (Exception ex)
        {
            _ok = false; _message = ex.Message;
        }
        _busy = false;
    }

    private async Task SetEnabled(ServerId id, bool enabled)
    {
        await Supervisor.SetEnabledAsync(id, enabled, CancellationToken.None);
        UiAudit.Record(Audit, Time, await UserAsync(), AuditEventKind.ConfigChanged, enabled ? "server-enabled" : "server-disabled", id);
        Reload();
    }

    private async Task Remove(ServerId id, string slug)
    {
        await Supervisor.RemoveAsync(id, DrainPolicy.Graceful(TimeSpan.FromSeconds(5)), CancellationToken.None);
        UiAudit.Record(Audit, Time, await UserAsync(), AuditEventKind.ConfigChanged, $"server-removed:{slug}", id);
        Reload();
    }
}

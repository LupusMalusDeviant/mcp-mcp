@page "/login"
@layout EmptyLayout
@attribute [AllowAnonymous]

@* Cookie-Login: nativer Form-POST an /auth/login, weil ein Blazor-Circuit keine Cookies setzen kann (WP6.1). *@
<div class="login-wrap">
    <div class="card login-card">
        <div class="brand" style="padding:0 0 1rem">MCP<span>-</span>MCP</div>
        <h3 style="margin-top:0">Anmelden</h3>
        <form action="/auth/login" method="post">
            <AntiforgeryToken />
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />
            <label for="username">Benutzername</label>
            <input id="username" name="username" autocomplete="username" autofocus />
            <label for="password">Passwort</label>
            <input id="password" name="password" type="password" autocomplete="current-password" />
            <button type="submit" style="width:100%; margin-top:1rem">Anmelden</button>
        </form>
        @if (Failed)
        {
            <p class="msg-err" style="margin-bottom:0">Benutzername oder Passwort falsch.</p>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "failed")]
    public bool Failed { get; set; }
}
